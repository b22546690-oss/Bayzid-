{
  "rewrite_rules": [
    {
      "source": "/(.*)",
      "destination": "api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@0.0.6"
    }
  },
  "routes": [
    {
      "src": "/webhook",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
